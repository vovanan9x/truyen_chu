import { Metadata } from 'next'
import Link from 'next/link'
import { prisma } from '@/lib/prisma'
import { formatNumber, formatDate } from '@/lib/utils'
import { CheckCircle, BookOpen, Eye, Star } from 'lucide-react'

export const metadata: Metadata = {
  title: 'Truyện hoàn thành',
  description: 'Danh sách truyện đã hoàn thành trên TruyenChu — đọc không lo chờ',
}

const PER_PAGE = 24

export default async function CompletedPage({ searchParams }: { searchParams: { page?: string; sort?: string } }) {
  const page = Math.max(1, parseInt(searchParams.page ?? '1'))
  const sort = searchParams.sort ?? 'updated'

  const orderBy = sort === 'views' ? { viewCount: 'desc' as const }
    : sort === 'rating' ? { rating: 'desc' as const }
    : { updatedAt: 'desc' as const }

  const [stories, total] = await Promise.all([
    prisma.story.findMany({
      where: { status: 'COMPLETED' },
      take: PER_PAGE, skip: (page - 1) * PER_PAGE,
      orderBy,
      select: {
        id: true, title: true, slug: true, coverUrl: true, author: true,
        viewCount: true, rating: true, ratingCount: true, updatedAt: true,
        _count: { select: { chapters: true } },
        genres: { take: 3, include: { genre: { select: { name: true, slug: true } } } },
      },
    }),
    prisma.story.count({ where: { status: 'COMPLETED' } }),
  ])

  const totalPages = Math.ceil(total / PER_PAGE)
  const sortOptions = [
    { value: 'updated', label: 'Mới cập nhật' },
    { value: 'views', label: 'Xem nhiều' },
    { value: 'rating', label: 'Đánh giá cao' },
  ]

  return (
    <div className="space-y-6">
      <div className="flex items-center justify-between flex-wrap gap-4">
        <div className="flex items-center gap-3">
          <CheckCircle className="w-6 h-6 text-green-500" />
          <div>
            <h1 className="text-2xl font-bold">Truyện hoàn thành</h1>
            <p className="text-sm text-muted-foreground">{formatNumber(total)} bộ truyện</p>
          </div>
        </div>
        <div className="flex gap-2">
          {sortOptions.map(opt => (
            <Link key={opt.value} href={`/truyen-hoan-thanh?sort=${opt.value}&page=1`}
              className={`px-3 py-2 rounded-xl text-sm font-medium transition-colors ${
                sort === opt.value ? 'gradient-primary text-white shadow-sm' : 'border border-border hover:bg-muted'
              }`}>
              {opt.label}
            </Link>
          ))}
        </div>
      </div>

      <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {stories.map(story => (
          <Link key={story.id} href={`/truyen/${story.slug}`}
            className="group flex flex-col rounded-xl overflow-hidden border border-border bg-card hover:border-primary/40 hover:shadow-md transition-all">
            <div className="relative aspect-[2/3]">
              <img src={story.coverUrl ?? 'https://picsum.photos/seed/' + story.slug + '/200/300'}
                alt={story.title} className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
              <div className="absolute top-1.5 right-1.5">
                <span className="px-1.5 py-0.5 rounded-md bg-green-500 text-white text-[10px] font-bold shadow">Xong</span>
              </div>
              {story.rating > 0 && (
                <div className="absolute bottom-1.5 left-1.5 flex items-center gap-0.5 bg-black/60 text-white px-1.5 py-0.5 rounded-md text-[10px]">
                  <Star className="w-2.5 h-2.5 fill-amber-400 text-amber-400" />
                  {story.rating.toFixed(1)}
                </div>
              )}
            </div>
            <div className="p-2.5 flex flex-col gap-1 flex-1">
              <p className="text-xs font-semibold line-clamp-2 leading-tight group-hover:text-primary transition-colors">{story.title}</p>
              <p className="text-[11px] text-muted-foreground truncate">{story.author ?? 'Đang cập nhật'}</p>
              <div className="flex items-center gap-1.5 text-[11px] text-muted-foreground mt-auto">
                <BookOpen className="w-3 h-3" /> {story._count.chapters}
                <Eye className="w-3 h-3 ml-1" /> {formatNumber(story.viewCount)}
              </div>
            </div>
          </Link>
        ))}
      </div>

      {totalPages > 1 && (
        <div className="flex justify-center gap-2 flex-wrap">
          {page > 1 && <Link href={`/truyen-hoan-thanh?sort=${sort}&page=${page - 1}`} className="px-4 py-2 rounded-xl border border-border hover:bg-muted text-sm">← Trước</Link>}
          {Array.from({ length: Math.min(totalPages, 8) }, (_, i) => i + 1).map(p => (
            <Link key={p} href={`/truyen-hoan-thanh?sort=${sort}&page=${p}`}
              className={`w-9 h-9 flex items-center justify-center rounded-xl text-sm font-medium ${p === page ? 'gradient-primary text-white shadow-sm' : 'border border-border hover:bg-muted'}`}>
              {p}
            </Link>
          ))}
          {page < totalPages && <Link href={`/truyen-hoan-thanh?sort=${sort}&page=${page + 1}`} className="px-4 py-2 rounded-xl border border-border hover:bg-muted text-sm">Tiếp →</Link>}
        </div>
      )}
    </div>
  )
}
