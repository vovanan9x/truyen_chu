# Nginx config for truyen-chu — Cloudflare Flexible SSL
#
# Cloudflare Flexible: User ←HTTPS→ Cloudflare ←HTTP→ VPS (port 80)
# → Nginx KHÔNG cần SSL cert, KHÔNG cần redirect HTTP→HTTPS
# → Phải trust Cloudflare headers để lấy IP thật của user
#
# Đặt tại: /etc/nginx/sites-available/truyen-chu
# Symlink:  ln -s /etc/nginx/sites-available/truyen-chu /etc/nginx/sites-enabled/

# Rate limiting zones (dùng CF-Connecting-IP thay vì $binary_remote_addr)
limit_req_zone $http_cf_connecting_ip zone=api:10m rate=30r/m;
limit_req_zone $http_cf_connecting_ip zone=web:10m rate=60r/s;

# Upstream Next.js
upstream nextjs {
    server 127.0.0.1:3000;
    keepalive 64;
}

server {
    listen 80;
    server_name yourdomain.com www.yourdomain.com;

    # ── Gzip Compression ─────────────────────────────────────────────────────
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types
        text/plain text/css text/xml text/javascript
        application/json application/javascript application/xml
        image/svg+xml font/woff font/woff2;

    # ── Upload limit (avatar upload) ──────────────────────────────────────────
    client_max_body_size 10M;

    # ── Cloudflare: lấy IP thật từ header CF-Connecting-IP ───────────────────
    # Danh sách IP Cloudflare: https://www.cloudflare.com/ips/
    set_real_ip_from 103.21.244.0/22;
    set_real_ip_from 103.22.200.0/22;
    set_real_ip_from 103.31.4.0/22;
    set_real_ip_from 104.16.0.0/13;
    set_real_ip_from 104.24.0.0/14;
    set_real_ip_from 108.162.192.0/18;
    set_real_ip_from 131.0.72.0/22;
    set_real_ip_from 141.101.64.0/18;
    set_real_ip_from 162.158.0.0/15;
    set_real_ip_from 172.64.0.0/13;
    set_real_ip_from 173.245.48.0/20;
    set_real_ip_from 188.114.96.0/20;
    set_real_ip_from 190.93.240.0/20;
    set_real_ip_from 197.234.240.0/22;
    set_real_ip_from 198.41.128.0/17;
    set_real_ip_from 2400:cb00::/32;
    real_ip_header CF-Connecting-IP;

    # ── Static files từ .next/static ─────────────────────────────────────────
    location /_next/static/ {
        proxy_pass http://nextjs;
        expires 365d;
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
    }

    # ── Uploads (ảnh bìa crawl về) — serve trực tiếp, KHÔNG qua Next.js ───────
    # Đổi path bên dưới thành đường dẫn thực tế trên VPS
    location /uploads/ {
        alias /var/www/truyen_chu/public/uploads/;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
        access_log off;
        # Trả 404 nếu file không tồn tại (thay vì fallback về Next.js)
        try_files $uri =404;
    }

    # ── Next.js Image Optimization ───────────────────────────────────────────
    location /_next/image {
        proxy_pass http://nextjs;
        expires 7d;
        add_header Cache-Control "public, max-age=604800";
    }

    # ── API Routes — rate limit chặt hơn ─────────────────────────────────────
    location /api/ {
        limit_req zone=api burst=20 nodelay;
        proxy_pass http://nextjs;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $http_cf_connecting_ip;
        proxy_set_header X-Forwarded-For $http_cf_connecting_ip;
        proxy_set_header X-Forwarded-Proto https; # Báo Next.js đây là HTTPS request
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 60s;
    }

    # ── SSE (Server-Sent Events) — tắt buffering ─────────────────────────────
    location /api/notifications/stream {
        proxy_pass http://nextjs;
        proxy_http_version 1.1;
        proxy_set_header Connection '';
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_set_header X-Real-IP $http_cf_connecting_ip;
        proxy_set_header X-Forwarded-For $http_cf_connecting_ip;
        proxy_set_header X-Forwarded-Proto https;
        chunked_transfer_encoding on;
    }

    # ── Tất cả routes còn lại → Next.js ──────────────────────────────────────
    location / {
        limit_req zone=web burst=30 nodelay;
        proxy_pass http://nextjs;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $http_cf_connecting_ip;
        proxy_set_header X-Forwarded-For $http_cf_connecting_ip;
        proxy_set_header X-Forwarded-Proto https;
        proxy_cache_bypass $http_upgrade;
    }
}
